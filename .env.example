# Copy to .env for local dev — never commit .env.
# On Vercel: Project → Settings → Environment Variables (Production + Preview).

# Required for `npm run build` (inlined into the client bundle)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Optional — social / contact links
# VITE_WHATSAPP_E164=972549470881
# VITE_INSTAGRAM_URL=https://www.instagram.com/your_page
# VITE_WHATSAPP_DEFAULT_MESSAGE=Hello!
# VITE_CONTACT_PHONE_DISPLAY=054-947-0881

# Server-only — Supabase auth in TanStack server functions (NOT VITE_*)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your_anon_public_key
#
# REQUIRED for customer order-confirmation emails (dedup + logging).
# Supabase → Project Settings → API → service_role (secret — never expose as VITE_*)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key

# Server-only — Resend email (NEVER use VITE_RESEND_API_KEY)
# RESEND_API_KEY=your_resend_api_key_here
# RESEND_FROM_EMAIL=Al-Nour Bakery <onboarding@resend.dev>
#
# For production: verify a custom domain in Resend (https://resend.com/domains)
# and replace onboarding@resend.dev with a real sender, e.g.:
#   RESEND_FROM_EMAIL=Al-Nour Bakery <orders@alnourbakery.com>
# Then set EMAIL_TEST_MODE=false to send to all subscribers / customers.

# Admin inbox for new-order notifications
# ADMIN_EMAIL=your-resend-account@gmail.com

# true  = test mode (emails only go to Resend's test inbox — safe for dev/staging)
# false = production mode (sends to real customer addresses)
# EMAIL_TEST_MODE=true

# Public URL used in email CTAs — no trailing slash (e.g. https://alnourbakery.com)
# APP_BASE_URL=https://alnourbakery.com
