# Copy to ".env" for local dev (never commit .env).
# For GitHub → production: add these same names as repository secrets and
# in your host’s build environment (Cloudflare Pages, Vercel, etc.).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use either name (same value from Supabase → Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# --- Customer site: WhatsApp + Instagram (required for those buttons / phone line) ---
# WhatsApp: country + national number without + (Israel 054… → 972549…)
VITE_WHATSAPP_E164=972549470881
# Instagram profile (full URL)
VITE_INSTAGRAM_URL=https://instagram.com/MadarLabs
# Pre-filled message when customers open WhatsApp (required if you want ?text= in the link). Use quotes if the text contains commas.
VITE_WHATSAPP_DEFAULT_MESSAGE="Hello, I would like to ask about your gluten-free bakery products."
# Optional: text shown next to phone icon; if omitted, a display line is derived from VITE_WHATSAPP_E164
# VITE_CONTACT_PHONE_DISPLAY=054-9470881

# Optional alias (app accepts this too)
# VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here

# --- Server only (TanStack server functions / deploy host) ---
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=same_as_VITE_SUPABASE_ANON_KEY
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Al-Nour Bakery <onboarding@resend.dev>
